APP_NAME=QuantiTop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quantitop
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

# --- Mail (2FA codes + password reset emails) ---
# For local/dev testing, use Mailtrap sandbox:
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@quantitop.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Two-Factor Auth tuning ---
TWO_FACTOR_CODE_LENGTH=6
TWO_FACTOR_CODE_TTL_MINUTES=10
TWO_FACTOR_MAX_ATTEMPTS=5
TWO_FACTOR_RESEND_COOLDOWN_SECONDS=30
